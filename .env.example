# ─── AWS ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-southeast-2

# ─── DynamoDB ───────────────────────────────────────────
DYNAMODB_TABLE_NAME=jobpilot-jobs

# ─── S3 ─────────────────────────────────────────────────
S3_BUCKET_NAME=jobpilot-resumes

# ─── SES (Email) ────────────────────────────────────────
SES_SENDER_EMAIL=your_verified_email@gmail.com
SES_RECIPIENT_EMAIL=your_email@gmail.com

# ─── Adzuna API ─────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# ─── Scraper Config ─────────────────────────────────────
SEEK_KEYWORDS=software developer,full stack developer,junior developer
SEEK_LOCATION=Melbourne VIC
SEEK_SALARY_MIN=70000

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000